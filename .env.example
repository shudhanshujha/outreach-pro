# Backend URL (Render production URL, or http://localhost:3001 for local dev)
BACKEND_URL=http://localhost:3001

# Frontend API URL (Vite reads this — Render production URL, or omit for local)
VITE_API_URL=http://localhost:3001

# Brevo SMTP API Key — send transactional & bulk emails
# Get yours at https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Gemini AI API Key — CSV header mapping & AI email writing
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Apollo.io API Key — lead enrichment & company search
# Get yours at https://apollo.io/settings/api-key
APOLLO_API_KEY=

# Supabase (PostgreSQL) — already hardcoded in api/db.js, override if needed
SUPABASE_URL=
SUPABASE_KEY=

# Render keepalive (auto-detected from BACKEND_URL if not set)
KEEPALIVE_URL=
